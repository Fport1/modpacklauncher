{
  "name": "modpack-launcher",
  "version": "0.9.6",
  "description": "Cross-platform Minecraft modpack launcher with auto-update support",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "clean": "node -e \"require('fs-extra').emptyDirSync('dist')\"",
    "dist:win": "npm run clean && electron-vite build && electron-builder --win",
    "dist:mac": "npm run clean && electron-vite build && electron-builder --mac",
    "dist:linux": "npm run clean && electron-vite build && electron-builder --linux",
    "dist": "npm run clean && electron-vite build && electron-builder"
  },
  "dependencies": {
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "adm-zip": "^0.5.12",
    "axios": "^1.7.2",
    "fs-extra": "^11.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "zustand": "^4.5.3"
  }
}
